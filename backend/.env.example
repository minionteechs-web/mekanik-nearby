PORT=5000
NODE_ENV=development

# Cloud Postgres (Neon/Supabase) — use this OR the individual DB_* vars below
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mekanik_nearby

JWT_SECRET=change_this_to_a_long_random_secret

# Public URL of this API (for absolute media links in chat)
PUBLIC_URL=http://localhost:5000

# Web app URL (for password reset links logged in dev; set when you add email)
APP_URL=http://localhost:5173

# Comma-separated allowed origins for CORS (production)
# CORS_ORIGINS=https://yourapp.com,https://www.yourapp.com
