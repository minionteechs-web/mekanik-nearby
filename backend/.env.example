# Cloud Postgres (Neon/Supabase) — use this OR the individual DB_* vars below
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mekanik_nearby

JWT_SECRET=change_this_to_a_long_random_secret

# Public URL of this API (for absolute media links in chat)
PUBLIC_URL=http://localhost:5000

# Web app URL (for password reset links)
APP_URL=http://localhost:5173

# Comma-separated allowed origins for CORS (production)
# CORS_ORIGINS=https://yourapp.com,https://www.yourapp.com

# Email (SMTP) — password reset emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=Mekanik Nearby <noreply@mekaniknearby.com>

# SMS (Termii — Nigeria)
# TERMII_API_KEY=your_termii_key
# TERMII_SENDER_ID=Mekanik

# Optional SMS webhook for custom provider
# SMS_WEBHOOK_URL=https://your-sms-provider/webhook

# Admin promotion on boot (optional)
# ADMIN_EMAIL=admin@example.com

# S3-compatible storage (optional — avatars/media persist across deploys)
# AWS_S3_BUCKET=mekanik-uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1
# AWS_S3_PUBLIC_URL=https://your-bucket.s3.amazonaws.com
